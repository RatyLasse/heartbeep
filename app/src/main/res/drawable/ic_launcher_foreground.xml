<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Geometric low-poly heart outline with internal facet lines.
        Outer polygon vertices (clockwise from top-center V):
          (54,26) (40,17) (25,16) (15,27) (15,44) (26,56)
          (54,84) (82,56) (93,44) (93,27) (83,16) (68,17)
        Internal lines:
          Left lobe X:  (25,16)→(15,44)  and  (15,27)→(40,17)
          Right lobe X: (83,16)→(93,44)  and  (93,27)→(68,17)
          Inner diagonals: (40,17)→(26,56)  and  (68,17)→(82,56)
          Lower-V:      (26,56)→(54,26)  and  (82,56)→(54,26)
    -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,26 L 40,17 L 25,16 L 15,27 L 15,44 L 26,56 L 54,84 L 82,56 L 93,44 L 93,27 L 83,16 L 68,17 Z
                          M 25,16 L 15,44
                          M 15,27 L 40,17
                          M 83,16 L 93,44
                          M 93,27 L 68,17
                          M 40,17 L 26,56
                          M 68,17 L 82,56
                          M 26,56 L 54,26
                          M 82,56 L 54,26"
        android:strokeColor="@color/launcher_heart_stroke"
        android:strokeWidth="3"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

    <!-- ECG waveform: flat baseline with QRS spike and T wave -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 15,56 L 28,56 L 32,59 L 37,51 L 43,38 L 48,62 L 53,56 L 61,56 L 65,51 L 68,47 L 72,56 L 93,56"
        android:strokeColor="@color/launcher_pulse"
        android:strokeWidth="3"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

</vector>
